[Unit]
Description=Bandwidth Credit System Analyzer
After=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/bin/python3 /opt/bandwidth_monitor/analyzer.py --auto
StandardOutput=journal
StandardError=journal
SyslogIdentifier=bandwidth-analyzer

NoNewPrivileges=yes
ProtectSystem=strict
ReadOnlyPaths=/var/log/bandwidth
ProtectHome=yes
PrivateTmp=yes
